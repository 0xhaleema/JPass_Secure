' ===================================================
' FIX 13: AccessController - dedicated security layer
' between UI (JPassFrame) and data (DataModel)
' ===================================================
class AccessController {
  -{static} instance: AccessController
  -currentSessionToken: String
  -failedAttempts: int
  -{static} MAX_FAILED_ATTEMPTS: int = 3
  -lockoutUntil: long
  --
  +{static} getInstance(): AccessController
  +authenticate(password: char[]): String
  +isAuthorized(sessionToken: String): boolean
  +revokeSession(sessionToken: String): void
  +recordFailedAttempt(): void
  +isLockedOut(): boolean
  +resetFailedAttempts(): void
  -generateSessionToken(): String
}

note right of AccessController
  FIX 13: NEW dedicated security layer sitting
  between ALL UI classes and DataModel.
  JPassFrame, EntryHelper, FileHelper, Worker
  must call isAuthorized() before any data access.
  Tracks failed login attempts and enforces
  lockout after MAX_FAILED_ATTEMPTS failures.
  generateSessionToken() creates cryptographically
  random token using SecureRandom
end note

' ===================================================
' ===================================================
class CryptInputStream {
  -{static} FETCH_BUFFER_SIZE: int
  -_parent: InputStream
  -_cipher: Cbc
  -_buffer: byte[]
  -_iv: byte[]
  --
  +CryptInputStream(parent: JPassInputStream)
  +CryptInputStream(parent: InputStream, key: byte[], iv: byte[])
  +validateIV(iv: byte[]): boolean
  +isIVReused(iv: byte[]): boolean
  +read(): int
  +close(): void
}

class CryptOutputStream {
  -_cipher: Cbc
  -_buffer: byte[]
  -_iv: byte[]
  -usedIVs: Set<String>
  --
  +CryptOutputStream(parent: OutputStream, key: byte[], iv: byte[])
  +generateUniqueIV(): byte[]
  +validateUniqueIV(iv: byte[]): boolean
  +write(b: int): void
  +write(b: byte[]): void
  +close(): void
  +finishEncryption(): void
}

note right of CryptOutputStream
  FIX 14: generateUniqueIV() creates new
  random IV for each encryption session.
  usedIVs tracks previous IVs to prevent
  reuse across sessions
end note

