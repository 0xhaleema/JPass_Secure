title JPass Secure Class Diagram\n(Security Redesign - All 18 Issues Addressed)

' ===================================================
' FIX 1, 2, 6, 13: DataModel - Password cleared after use,
' Access control added, In-memory encryption, Security layer
' ===================================================
class DataModel {
  -{static} instance: DataModel
  -encryptedEntries: byte[]
  -entriesKey: byte[]
  -fileName: String
  -password: char[]
  -modified: boolean
  -sessionToken: String
  -lastActivityTime: long
  -{static} SESSION_TIMEOUT_MS: long = 300000
  --
  +{static} getInstance(): DataModel
  +getEntries(sessionToken: String): Entries
  +setEntries(entries: Entries, sessionToken: String): void
  -encryptEntries(entries: Entries): byte[]
  -decryptEntries(sessionToken: String): Entries
  +getFileName(): String
  +setFileName(name: String): void
  -getPassword(): char[]
  +setPassword(pass: char[]): void
  +isModified(): boolean
  +setModified(modified: boolean): void
  +clear(): void
  +clearPasswordFromMemory(): void
  +validateSession(token: String): boolean
  +refreshSession(): void
  +isSessionExpired(): boolean
}

note right of DataModel
  FIX 1: clearPasswordFromMemory() wipes char[]
  with Arrays.fill() - password never lingers in RAM
  FIX 2: getEntries() requires valid sessionToken
  FIX 6: encryptedEntries:byte[] stores data AES-encrypted.
  encryptEntries() encrypts before storing,
  decryptEntries() decrypts only when session valid.
  getPassword() changed to private - no external access
  FIX 8: isSessionExpired() auto-locks after 5 min
  FIX 13: sessionToken validates ALL data access
end note

