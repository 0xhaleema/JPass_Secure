' ===================================================
' FIX 18: Worker - authentication check added
' ===================================================
abstract class Worker {
  -parent: JPassFrame
  -authenticated: boolean
  --
  +Worker(parent: JPassFrame)
  #done(): void
  #showErrorMessage(e: Exception): void
  #stopProcessing(): void
  #isAuthenticated(): boolean
  #requireAuthentication(): boolean
  #executeIfAuthenticated(task: Runnable): void
}

note right of Worker
  FIX 18: requireAuthentication()
  verifies session is valid before
  executing any background task.
  executeIfAuthenticated() wraps
  all sensitive operations
end note

